# Oracle APEX MCP Server — Configuration
# Copy to .env and edit values

ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=XE
ORACLE_USERNAME=hr
ORACLE_PASSWORD=hr

# Alternative: TNS Alias (from tnsnames.ora)
# ORACLE_TNS_ALIAS=MYDB

# Alternative: Full TNS Connect String
# ORACLE_CONNECTION_STRING=(DESCRIPTION=(ADDRESS=(PROTOCOL=tcp)(HOST=myhost)(PORT=1521))(CONNECT_DATA=(SERVICE_NAME=MYDB)))

# TNS Discovery
# TNS_ADMIN=C:\oracle\network\admin
# ORACLE_HOME=C:\oracle
# TNS_NAMES_FILE=C:\oracle\network\admin\tnsnames.ora

# Pool Configuration
ORACLE_POOL_MIN=1
ORACLE_POOL_MAX=10
ORACLE_POOL_TIMEOUT=60
ORACLE_STMT_CACHE_SIZE=30
ORACLE_FETCH_SIZE=100

# Legacy Oracle (pre-12c crypto)
# ORACLE_OLD_CRYPTO=true
# ORACLE_CLIENT_LIB_DIR=C:\oracle\instantclient_19_26
